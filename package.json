{
  "name": "pathfinder-game",
  "private": true,
  "type": "module",
  "scripts": {
    "lint:solver": "node scripts/lint-solver-no-undef.mjs",
    "test:solver-smoke": "node scripts/solver-smoke-test.mjs",
    "check:audit-output": "node scripts/check-audit-output.mjs",
    "ci": "npm run lint:solver && npm run test:solver-smoke && npm run test:startup-smoke",
    "test:startup-smoke": "node scripts/startup-smoke-test.mjs",
    "audit:newhint:full": "node scripts/run-audit-export.mjs",
    "audit:analyze-failures": "node scripts/analyze-audit-failures.mjs",
    "audit:check-hard-levels": "node scripts/check-persistent-hard-levels.mjs",
    "audit:check-hard-levels:strict": "node scripts/check-persistent-hard-levels.mjs --enforce-solved",
    "audit:check-regressions": "node scripts/check-regression-levels.mjs --levels=7 --window=3 --max-consecutive-failures=1",
    "audit:heuristic-recall": "node scripts/audit-heuristic-recall.mjs --levels=92,108,134 --output=audits/heuristic-recall/latest.json"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
